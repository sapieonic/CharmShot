{
  "name": "charmshot-backend",
  "version": "2.0.0",
  "private": true,
  "description": "CharmShot - AI image generation backend (identity-preserving photo enhancement)",
  "type": "commonjs",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "npm run test:unit && npm run test:integration",
    "lint": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/server/index.js",
    "dev": "tsx watch --env-file=.env src/server/index.ts",
    "openapi:export": "tsx scripts/export-openapi.ts",
    "openapi:check": "tsx scripts/check-openapi.ts",
    "release": "semantic-release",
    "commitlint": "commitlint",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "@aws-sdk/client-s3": "^3.654.0",
    "@aws-sdk/s3-request-presigner": "^3.654.0",
    "@fastify/cors": "^8.5.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.2.0",
    "@opentelemetry/api-logs": "^0.218.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-logs": "^0.218.0",
    "fastify": "^4.29.1",
    "firebase-admin": "^12.5.0",
    "mongodb": "^6.9.0",
    "posthog-node": "^5.36.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^22.7.4",
    "@vitest/coverage-v8": "^2.1.1",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "esbuild": "^0.24.0",
    "husky": "^9.1.7",
    "semantic-release": "^24.2.9",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1",
    "yaml": "^2.9.0"
  }
}
