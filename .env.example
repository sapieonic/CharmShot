# ============================================================================
# CharmShot backend — environment variables
#
# In production, secrets are pulled from AWS Secrets Manager (see SECRETS_* and
# *_SECRET_ARN below). These env vars are primarily for local development and
# for non-secret runtime configuration of the Lambdas.
# ============================================================================

# --- Runtime / general ------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info
AWS_REGION=us-east-1

# --- MongoDB ----------------------------------------------------------------
# For local dev you can point at a local mongo or Atlas. In production this is
# resolved from Secrets Manager via MONGODB_SECRET_ARN.
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=charmshot
# ARN of the Secrets Manager secret holding { "uri": "..." }
MONGODB_SECRET_ARN=

# --- S3 ---------------------------------------------------------------------
UPLOADS_BUCKET=charmshot-uploads
RESULTS_BUCKET=charmshot-results
# Seconds that presigned upload/download URLs remain valid
UPLOAD_URL_TTL_SECONDS=900
RESULT_URL_TTL_SECONDS=900
MAX_UPLOAD_BYTES=10485760

# --- SQS --------------------------------------------------------------------
GENERATION_QUEUE_URL=

# --- Firebase ---------------------------------------------------------------
FIREBASE_PROJECT_ID=charmshot-dev
# ARN of Secrets Manager secret holding the Firebase service account JSON.
# If unset, the app falls back to JWKS verification using FIREBASE_PROJECT_ID.
FIREBASE_SERVICE_ACCOUNT_SECRET_ARN=

# --- RevenueCat -------------------------------------------------------------
# ARN of Secrets Manager secret holding { "authHeader": "..." } used to verify
# the Authorization header on incoming RevenueCat webhooks.
REVENUECAT_SECRET_ARN=
# Local-dev fallback for the expected webhook auth header value
REVENUECAT_WEBHOOK_AUTH=dev-revenuecat-secret

# --- Model providers --------------------------------------------------------
# ARN of Secrets Manager secret holding provider API keys, e.g.
# { "nanoBananaApiKey": "..." }
PROVIDER_SECRETS_ARN=
NANO_BANANA_API_KEY=dev-nano-banana-key
NANO_BANANA_BASE_URL=https://api.nanobanana.example.com

# Default model routing
DEFAULT_MODEL_ID=nano-banana
FALLBACK_MODEL_ID=nano-banana

# --- Credits / entitlements -------------------------------------------------
FREE_TIER_CREDITS=10
# Refund credits automatically when a job fails
REFUND_ON_FAILURE=true

# --- Rate limiting ----------------------------------------------------------
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=60

# --- Observability ----------------------------------------------------------
METRICS_NAMESPACE=CharmShot
METRICS_ENABLED=true
