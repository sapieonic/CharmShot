# ============================================================================
# CharmShot backend — environment variables
#
# The service runs as a long-lived server (Fastify) with an in-process worker.
# All configuration, including secrets, comes from environment variables.
# The only external AWS dependency is S3. For local dev you can load this file
# with `node --env-file=.env dist/server/index.js` or via docker compose.
# ============================================================================

# --- Server -----------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info
PORT=8080
HOST=0.0.0.0
BODY_LIMIT_BYTES=1048576

# --- Background worker (in-process) -----------------------------------------
WORKER_ENABLED=true
WORKER_CONCURRENCY=2

# --- MongoDB ----------------------------------------------------------------
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=charmshot

# --- S3 (the only external AWS dependency) ----------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
UPLOADS_BUCKET=charmshot-uploads
RESULTS_BUCKET=charmshot-results
UPLOAD_URL_TTL_SECONDS=900
RESULT_URL_TTL_SECONDS=900
MAX_UPLOAD_BYTES=10485760
# Optional: point at an S3-compatible server (MinIO/LocalStack) for local dev.
# S3_ENDPOINT=http://localhost:9000
# S3_FORCE_PATH_STYLE=true

# --- Firebase Auth ----------------------------------------------------------
FIREBASE_PROJECT_ID=charmshot-dev
# Full service-account JSON as a single-line string. If unset, tokens are
# verified against Google's public JWKS using the project id alone.
FIREBASE_SERVICE_ACCOUNT_JSON=

# --- RevenueCat webhook -----------------------------------------------------
# Expected Authorization header value on incoming webhooks.
REVENUECAT_WEBHOOK_AUTH=dev-revenuecat-secret

# --- Model providers --------------------------------------------------------
NANO_BANANA_API_KEY=dev-nano-banana-key
NANO_BANANA_BASE_URL=https://api.nanobanana.example.com
DEFAULT_MODEL_ID=nano-banana
FALLBACK_MODEL_ID=nano-banana

# --- Credits / free tier ----------------------------------------------------
FREE_TIER_CREDITS=10
REFUND_ON_FAILURE=true

# --- Rate limiting ----------------------------------------------------------
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=60

# --- Observability ----------------------------------------------------------
METRICS_NAMESPACE=CharmShot
METRICS_ENABLED=true
