# ============================================================================
# CharmShot backend — environment variables
#
# The service runs as a long-lived server (Fastify) with an in-process worker.
# All configuration, including secrets, comes from environment variables.
# The only external AWS dependency is S3. For local dev you can load this file
# with `node --env-file=.env dist/server/index.js` or via docker compose.
# ============================================================================

# --- Server -----------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info
PORT=8080
HOST=0.0.0.0
BODY_LIMIT_BYTES=1048576

# --- Background worker (in-process) -----------------------------------------
WORKER_ENABLED=true
WORKER_CONCURRENCY=2

# --- MongoDB ----------------------------------------------------------------
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=charmshot

# --- S3 (the only external AWS dependency) ----------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
UPLOADS_BUCKET=charmshot-uploads
RESULTS_BUCKET=charmshot-results
UPLOAD_URL_TTL_SECONDS=900
RESULT_URL_TTL_SECONDS=900
MAX_UPLOAD_BYTES=10485760
# Optional: point at an S3-compatible server (MinIO/LocalStack) for local dev.
# S3_ENDPOINT=http://localhost:9000
# S3_FORCE_PATH_STYLE=true

# --- Firebase Auth ----------------------------------------------------------
FIREBASE_PROJECT_ID=charmshot-dev
# Full service-account JSON as a single-line string. If unset, tokens are
# verified against Google's public JWKS using the project id alone.
FIREBASE_SERVICE_ACCOUNT_JSON=

# --- Payments (Razorpay — shell integration) ---------------------------------
# Master switch for the payments surface. When false (default) the Razorpay
# webhook returns 503 and no payment processing occurs.
PAYMENTS_ENABLED=false
# Razorpay API credentials (used by the future order/checkout flow).
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
# RAZORPAY_KEY_SECRET=
# Secret used to verify the X-Razorpay-Signature header on webhooks.
RAZORPAY_WEBHOOK_SECRET=dev-razorpay-webhook-secret

# --- Model providers --------------------------------------------------------
# "Nano Banana" = Google's Gemini image models, via the Gemini API.
# NANO_BANANA_API_KEY is a Google AI Studio / Gemini API key.
# Default model is Nano Banana 2 (Gemini 3.1 Flash Image).
NANO_BANANA_API_KEY=dev-nano-banana-key
NANO_BANANA_BASE_URL=https://generativelanguage.googleapis.com/v1beta
NANO_BANANA_MODEL=gemini-3.1-flash-image-preview
# Optional output resolution (Nano Banana 2): 512 | 1K | 2K | 4K. Unset = model default.
# NANO_BANANA_IMAGE_SIZE=2K
#
# OpenAI Images API (gpt-image-1). OPENAI_API_KEY is a standard OpenAI API key.
# With reference selfies present we call the image edits endpoint (identity
# preservation); otherwise text-to-image generations.
OPENAI_API_KEY=dev-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=gpt-image-1
# Optional gpt-image-1 quality: low | medium | high | auto. Unset = model default.
# OPENAI_IMAGE_QUALITY=high
# Optional output format: png (default) | jpeg | webp.
# OPENAI_IMAGE_OUTPUT_FORMAT=png
# Optional fixed size: 1024x1024 | 1536x1024 | 1024x1536 | auto.
# Unset = derived from the request's aspect ratio.
# OPENAI_IMAGE_SIZE=1024x1024
#
# Which model runs jobs is selected here (env-controlled for now; per-user later).
# Set DEFAULT_MODEL_ID=openai to route jobs to OpenAI instead of nano-banana.
DEFAULT_MODEL_ID=nano-banana
FALLBACK_MODEL_ID=nano-banana

# --- Credits / free tier ----------------------------------------------------
FREE_TIER_CREDITS=10
REFUND_ON_FAILURE=true

# --- Rate limiting ----------------------------------------------------------
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=60

# --- Observability ----------------------------------------------------------
METRICS_NAMESPACE=CharmShot
METRICS_ENABLED=true

# --- PostHog (analytics, AI observability, logs) ----------------------------
# Disabled by default; set POSTHOG_ENABLED=true and provide a project API key.
POSTHOG_ENABLED=false
# POSTHOG_API_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_FLUSH_AT=20
POSTHOG_FLUSH_INTERVAL_MS=10000
POSTHOG_SYSTEM_DISTINCT_ID=charmshot-backend
# Ship structured logs to PostHog Logs over OTLP (uses the same API key/host).
POSTHOG_LOGS_ENABLED=false
POSTHOG_SERVICE_NAME=charmshot-api
